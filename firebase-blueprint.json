{
  "entities": {
    "Employee": {
      "title": "Employee",
      "description": "Employee with EPI receipt log history",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "age": { "type": "number" },
        "tools": { "type": "array", "items": { "type": "string" } },
        "photoUrl": { "type": "string" },
        "epis": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "epiName": { "type": "string" },
              "brand": { "type": "string" },
              "caNumber": { "type": "string" },
              "date": { "type": "string" },
              "signature": { "type": "string" }
            }
          }
        }
      },
      "required": ["name", "role", "age"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "description": "Inventory Item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "location": { "type": "string" },
        "qty": { "type": "number" },
        "minQty": { "type": "number" },
        "status": { "type": "string", "enum": ["OK", "WARNING", "CRITICAL", "OUT_OF_STOCK"] },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "location", "qty", "minQty", "status", "price"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Shipment",
      "type": "object",
      "properties": {
        "destination": { "type": "string" },
        "items": { "type": "number" },
        "status": { "type": "string" },
        "driver": { "type": "string" },
        "vehicle": { "type": "string" },
        "date": { "type": "string" }
      },
      "required": ["destination", "items", "status", "driver", "vehicle", "date"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "category", "rating", "phone", "email", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Company Settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "cnpj": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "lowStockAlerts": { "type": "boolean" },
        "shipmentUpdates": { "type": "boolean" },
        "dailyEmail": { "type": "boolean" },
        "externalAccessPin": { "type": "string" },
        "externalAccessEnabled": { "type": "boolean" }
      }
    },
    "Movement": {
      "title": "Inventory Movement",
      "description": "A movement of an inventory item",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["IN", "OUT"] },
        "qty": { "type": "number" },
        "reason": { "type": "string" },
        "date": { "type": "string" },
        "user": { "type": "string" },
        "userEmail": { "type": "string" }
      },
      "required": ["type", "qty", "reason", "date", "user", "userEmail"]
    },
    "Category": {
      "title": "Category",
      "description": "Inventory Category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "purpose": { "type": "string" },
        "photoUrl": { "type": "string" }
      },
      "required": ["name", "description", "purpose"]
    },
    "QualityReport": {
      "title": "Quality Report",
      "description": "Quality Control Evaluation Report",
      "type": "object",
      "properties": {
        "productName": { "type": "string" },
        "inspectorName": { "type": "string" },
        "structureStatus": { "type": "boolean" },
        "hasImetro": { "type": "string" },
        "hasLabSeal": { "type": "string" },
        "hasSafetySeals": { "type": "string" },
        "notes": { "type": "string" },
        "signature": { "type": "string" },
        "status": { "type": "string", "enum": ["APPROVED", "DISAPPROVED"] },
        "type": { "type": "string", "enum": ["LOTE", "PRODUTO", "CAIXA"] },
        "date": { "type": "string" }
      },
      "required": ["productName", "inspectorName", "structureStatus", "signature", "status", "type", "date"]
    }
  },
  "firestore": {
    "/organizations/{orgId}/quality_control/{reportId}": {
      "schema": { "$ref": "#/entities/QualityReport" },
      "description": "Tenant Quality Control Evaluation Reports Collection"
    },
    "/organizations/{orgId}/inventory/{itemId}": {
      "schema": { "$ref": "#/entities/InventoryItem" },
      "description": "Tenant Inventory Items Collection"
    },
    "/organizations/{orgId}/inventory/{itemId}/movements/{movementId}": {
      "schema": { "$ref": "#/entities/Movement" },
      "description": "Inventory item movements"
    },
    "/organizations/{orgId}/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Tenant Categories Collection"
    },
    "/organizations/{orgId}/shipments/{shipmentId}": {
      "schema": { "$ref": "#/entities/Shipment" },
      "description": "Tenant Shipments Collection"
    },
    "/organizations/{orgId}/suppliers/{supplierId}": {
      "schema": { "$ref": "#/entities/Supplier" },
      "description": "Tenant Suppliers Collection"
    },
    "/organizations/{orgId}/employees/{employeeId}": {
      "schema": { "$ref": "#/entities/Employee" },
      "description": "Tenant Employees and EPI Deliveries Collection"
    },
    "/organizations/{orgId}/settings/{settingsId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Tenant Settings Collection"
    },
    "/users/{uid}": {
      "schema": "object",
      "description": "User profiles including orgId and role"
    }
  }
}
